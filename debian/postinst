#!/bin/bash
# debian/postinst — 패키지 설치 후 처리
set -e

SHARE_DIR="/usr/share/rclone-azureblob-airgap"
STATE_DIR="/var/lib/rclone-azureblob-airgap"
FUSE_MANIFEST="${STATE_DIR}/fuse-runtime.manifest"

fuse_runtime_present() {
  command -v fusermount3 >/dev/null 2>&1 && find /lib /usr/lib -name libfuse3.so.3 -print -quit 2>/dev/null | grep -q .
}

fuse_runtime_bootstrapped() {
  [ -s "$FUSE_MANIFEST" ]
}

remove_bootstrapped_runtime() {
  [ -f "$FUSE_MANIFEST" ] || return 0
  while IFS= read -r target; do
    [ -n "$target" ] || continue
    if dpkg -S "$target" >/dev/null 2>&1; then
      continue
    fi
    rm -f "$target" 2>/dev/null || true
  done < "$FUSE_MANIFEST"
  rm -f "$FUSE_MANIFEST"
}

copy_tree_if_exists() {
  local src=$1
  local dest=$2
  local rel_path target
  [ -d "$src" ] || return 0
  while IFS= read -r rel_path; do
    [ -n "$rel_path" ] || continue
    target="$dest/$rel_path"
    if [ -e "$target" ]; then
      continue
    fi
  done < <(cd "$src" && find . \( -type f -o -type l \) -print | sed 's#^\./##')
  while IFS= read -r rel_path; do
    [ -n "$rel_path" ] || continue
    target="$dest/$rel_path"
    [ -e "$target" ] && continue
    mkdir -p "$(dirname "$target")"
    cp -a "$src/$rel_path" "$target"
    printf '%s\n' "$target" >> "$FUSE_MANIFEST"
  done < <(cd "$src" && find . \( -type f -o -type l \) -print | sed 's#^\./##')
}

# ── FUSE3 오프라인 자동 설치 헬퍼 ─────────────────────────────────────────────
install_fuse3_offline() {
  # 이미 사용 가능하면 건너뜀
  if fuse_runtime_present && ! fuse_runtime_bootstrapped; then
    echo "[rclone-airgap] FUSE3 runtime 이미 사용 가능, 건너뜀"
    return 0
  fi

  # OS 코드네임 감지
  local codename=""
  if [ -f /etc/os-release ]; then
    codename=$(. /etc/os-release && echo "${VERSION_CODENAME:-}")
    # 버전 ID 폴백
    if [ -z "$codename" ]; then
      local ver_id
      ver_id=$(. /etc/os-release && echo "${VERSION_ID:-}")
      case "$ver_id" in
        22.*) codename="jammy" ;;
        24.*) codename="noble" ;;
      esac
    fi
  fi

  # 지원 범위 확인
  case "$codename" in
    jammy|noble) ;;
    *)
      echo "[rclone-airgap] WARN: Ubuntu $codename 은 번들 FUSE deb 지원 외 버전"
      echo "[rclone-airgap]       시스템 패키지로 수동 설치 필요: apt-get install fuse3 libfuse3-3"
      return 0
      ;;
  esac

  # 아키텍처 감지
  local arch
  arch=$(dpkg --print-architecture)

  local deb_dir="${SHARE_DIR}/fuse-debs/${codename}"
  if [ ! -d "$deb_dir" ]; then
    echo "[rclone-airgap] WARN: FUSE deb 캐시 없음: $deb_dir"
    return 0
  fi

  local libpkg fuse3pkg
  libpkg=$(find "$deb_dir" -name "libfuse3-3_*_${arch}.deb" | head -1)
  fuse3pkg=$(find "$deb_dir" -name "fuse3_*_${arch}.deb"    | head -1)

  if [ -z "$libpkg" ] || [ -z "$fuse3pkg" ]; then
    echo "[rclone-airgap] WARN: $deb_dir 에서 ${arch} 용 deb 없음"
    return 0
  fi

  echo "[rclone-airgap] FUSE3 runtime 오프라인 부트스트랩 중 (codename=$codename arch=$arch)"
  local extract_root
  extract_root=$(mktemp -d /tmp/rclone-airgap-fuse-XXXXXX)
  remove_bootstrapped_runtime
  mkdir -p "$STATE_DIR"
  : > "$FUSE_MANIFEST"
  if ! dpkg-deb -x "$libpkg" "$extract_root/libfuse3"; then
    rm -rf "$extract_root"
    echo "[rclone-airgap] ERROR: libfuse3-3 runtime 추출 실패" >&2
    exit 1
  fi
  if ! dpkg-deb -x "$fuse3pkg" "$extract_root/fuse3"; then
    rm -rf "$extract_root"
    echo "[rclone-airgap] ERROR: fuse3 runtime 추출 실패" >&2
    exit 1
  fi
  copy_tree_if_exists "$extract_root/libfuse3/lib" /lib
  copy_tree_if_exists "$extract_root/libfuse3/usr/lib" /usr/lib
  copy_tree_if_exists "$extract_root/fuse3/bin" /bin
  copy_tree_if_exists "$extract_root/fuse3/sbin" /sbin
  copy_tree_if_exists "$extract_root/fuse3/usr/bin" /usr/bin
  copy_tree_if_exists "$extract_root/fuse3/usr/sbin" /usr/sbin
  sort -u "$FUSE_MANIFEST" -o "$FUSE_MANIFEST"
  rm -rf "$extract_root"
  if ! dpkg-statoverride --list /bin/fusermount3 > /dev/null 2>&1; then
    chmod 4755 /bin/fusermount3 2>/dev/null || chmod 4755 /usr/bin/fusermount3 2>/dev/null || true
  fi
  if command -v ldconfig > /dev/null 2>&1; then
    ldconfig 2>/dev/null || true
  fi
  if ! fuse_runtime_present; then
    echo "[rclone-airgap] ERROR: FUSE3 runtime 부트스트랩 후에도 fusermount3/libfuse3.so.3 미확인" >&2
    exit 1
  fi

  # udev 규칙 재로드 (fuse3 패키지가 99-fuse3.rules 설치)
  if command -v udevadm > /dev/null 2>&1; then
    udevadm control --reload-rules 2>/dev/null || true
    udevadm trigger            2>/dev/null || true
  fi

  # /dev/fuse 권한
  if [ -c /dev/fuse ]; then
    chmod 666 /dev/fuse 2>/dev/null || true
    echo "[rclone-airgap] /dev/fuse 권한 설정 (666)"
  else
    echo "[rclone-airgap] WARN: /dev/fuse 없음 — 커널 모듈 확인 필요: modprobe fuse"
  fi

  echo "[rclone-airgap] FUSE3 runtime 부트스트랩 완료 (fusermount3 + libfuse3.so.3)"
}

case "$1" in
  configure)
    # ── 1. FUSE3 자동 설치 (번들 deb 사용) ────────────────────────────────
    install_fuse3_offline

    # ── 2. fuse 그룹 생성 ─────────────────────────────────────────────────
    if ! getent group fuse > /dev/null 2>&1; then
      groupadd --system fuse
      echo "[rclone-airgap] fuse 그룹 생성됨"
    fi

    # ── 3. /etc/fuse.conf user_allow_other ────────────────────────────────
    if [ ! -f /etc/fuse.conf ]; then
      echo "user_allow_other" > /etc/fuse.conf
      echo "[rclone-airgap] /etc/fuse.conf 생성 (user_allow_other)"
    elif ! grep -q "^user_allow_other" /etc/fuse.conf; then
      echo "user_allow_other" >> /etc/fuse.conf
      echo "[rclone-airgap] /etc/fuse.conf 에 user_allow_other 추가"
    fi

    # ── 4. /etc/rclone 권한 ───────────────────────────────────────────────
    chmod 750 /etc/rclone /etc/rclone/mounts 2>/dev/null || true
    chmod 700 /etc/rclone/certs              2>/dev/null || true

    # ── 5. azure-env.conf 뼈대 (없을 때만) ───────────────────────────────
    if [ ! -f /etc/rclone/azure-env.conf ]; then
      install -m 600 /dev/null /etc/rclone/azure-env.conf
      cat >> /etc/rclone/azure-env.conf << 'EOF'
# Azure 인증 환경 변수 (env_auth 방식)
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_STORAGE_ACCOUNT_NAME=
EOF
      echo "[rclone-airgap] /etc/rclone/azure-env.conf 생성"
    fi

    # ── 6. rclone.conf 뼈대 (없을 때만) ──────────────────────────────────
    if [ ! -f /etc/rclone/rclone.conf ]; then
      install -m 640 /dev/null /etc/rclone/rclone.conf
      echo "[rclone-airgap] /etc/rclone/rclone.conf 생성"
    fi

    # ── 7. Azure 설정 템플릿 배치 ─────────────────────────────────────────
    if [ ! -f /etc/rclone/rclone-azureblob.conf.template ]; then
      install -m 640 \
        "$SHARE_DIR/azure/rclone-azureblob.conf" \
        /etc/rclone/rclone-azureblob.conf.template
      echo "[rclone-airgap] Azure Blob 설정 템플릿: /etc/rclone/rclone-azureblob.conf.template"
    fi

    # ── 8. mount 예시 파일 배치 ───────────────────────────────────────────
    for f in "$SHARE_DIR/azure/conf-examples/"*.conf; do
      [ -f "$f" ] || continue
      dest="/etc/rclone/mounts/$(basename "$f").example"
      if [ ! -f "$dest" ]; then
        install -m 640 "$f" "$dest"
      fi
    done

    # ── 9. systemd reload ─────────────────────────────────────────────────
    if command -v systemctl > /dev/null 2>&1 && \
       systemctl is-system-running --quiet 2>/dev/null; then
      systemctl daemon-reload || true
      echo "[rclone-airgap] systemd daemon-reload 완료"
    fi

    # ── 10. /usr/local/bin 심볼릭 링크 (하위 호환) ────────────────────────
    if [ ! -L /usr/local/bin/rclone ] && [ ! -f /usr/local/bin/rclone ]; then
      ln -sf /usr/bin/rclone /usr/local/bin/rclone 2>/dev/null || true
    fi

    # ── 완료 메시지 ───────────────────────────────────────────────────────
    echo ""
    echo "=============================================="
    echo " rclone-azureblob-airgap 설치 완료"
    echo " rclone    : $(rclone version 2>/dev/null | head -1 || echo 'N/A')"
    echo " fusermount3: $(command -v fusermount3 2>/dev/null || echo 'N/A')"
    echo " libfuse3  : $(find /lib /usr/lib -name libfuse3.so.3 -print -quit 2>/dev/null || echo 'N/A')"
    echo "=============================================="
    echo " 다음 단계:"
    echo "  1. bash /usr/share/rclone-azureblob-airgap/scripts/configure-azureblob.sh"
    echo "  2. bash /usr/share/rclone-azureblob-airgap/scripts/verify-azureblob.sh --remote <이름>"
    echo "  3. systemctl start rclone-azureblob@<이름>.service"
    echo "=============================================="
    ;;

  abort-install|abort-upgrade|abort-remove|abort-deconfigure)
    ;;

  *)
    echo "postinst: 알 수 없는 인수 $1" >&2
    exit 1
    ;;
esac

#DEBHELPER#
exit 0
